<!DOCTYPE html>
<html lang="pt-BR">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{{ title }}</title>
        
        <!-- SEO Meta Tags -->
        <meta name="description" content="{{ description or 'Evandro Martins - Desenvolvedor Full Stack com experiência em TypeScript, Angular, Node.js, NestJS, MongoDB e Data Engineering' }}" />
        <meta name="author" content="Evandro Martins" />
        <meta name="google-site-verification" content="Zu9BOjac8tK6_FpFsCyTb0m_1EYKdI6QCLIwuhuxsqw" />
        <link rel="canonical" href="https://martinsevandro.github.io{{ page.url }}" />
        
        <!-- Open Graph Tags (Social Media) -->
        <meta property="og:title" content="{{ title }}" />
        <meta property="og:description" content="{{ description or 'Portfólio e Blog técnico de Evandro Martins' }}" />
        <meta property="og:url" content="https://martinsevandro.github.io{{ page.url }}" />
        <meta property="og:type" content="{% if pageType == 'post' %}article{% elif pageType == 'curriculum' %}profile{% else %}website{% endif %}" />
        <meta property="og:image" content="https://martinsevandro.github.io{{ image or '/assets/imgs/perfil-ef-256.webp' }}" />
        <meta property="og:locale" content="pt_BR" />
        

        <link rel="preload" as="image" href="/assets/imgs/perfil-ef-256.webp">
        <link rel="stylesheet" href="/assets/styles.css" />
        <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@400;700&display=swap" rel="stylesheet">
        <link href="https://fonts.googleapis.com/css2?family=Inter&display=swap" rel="stylesheet">
        <link href='https://fonts.googleapis.com/css?family=Jaldi' rel='stylesheet'>
        <link href="https://fonts.cdnfonts.com/css/homizio" rel="stylesheet">
        <link href='https://fonts.googleapis.com/css?family=Open Sans' rel='stylesheet'>
        <link rel="icon" href="/assets/icons/favicon.ico" type="image/x-icon" />
        
        <!-- JSON-LD Structured Data -->
        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "{% if pageType == 'post' %}BlogPosting{% elif pageType == 'curriculum' %}Person{% else %}Person{% endif %}",
            {% if pageType == 'post' %}
            "headline": "{{ title }}",
            "description": "{{ description or 'Post técnico' }}",
            "image": "https://martinsevandro.github.io{{ image or '/assets/imgs/perfil-ef-256.webp' }}",
            "datePublished": "{{ date | date('yyyy-MM-dd') }}",
            "author": {
                "@type": "Person",
                "name": "{{ author or 'Evandro Martins' }}",
                "url": "https://martinsevandro.github.io"
            },
            "keywords": "{{ tags.join(', ') if tags else 'tecnologia, desenvolvimento' }}"
            {% else %}
            "name": "{{ title }}",
            "url": "https://martinsevandro.github.io",
            "image": "https://martinsevandro.github.io/assets/imgs/perfil-ef-256.webp",
            "description": "{{ description or 'Desenvolvedor Full Stack - TypeScript, Angular, Node.js, NestJS, MongoDB, Data Engineering' }}",
            "sameAs": [
                "https://github.com/martinsevandro",
                "https://linkedin.com/in/martinsevandro"
            ]
            {% endif %}
        }
        </script>
        
    </head>

    <body class="{{ pageType}}">
        <header></header>

        <main class="{% if pageType == "home" %}main-home{% elif pageType == "post" %}main-post{% elif pageType == "curriculum" %}main-curriculum{% else %}main-home{% endif %}">
            <div class="container">

                {% include "partials/perfil.njk" %}

                {% block content %}
                    {{ content | safe }}
                {% endblock %}

            </div>
        </main>

        <button id="backToTop" class="back-to-top" aria-label="Voltar ao topo">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M6 15L12 9L18 15"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"/>
            </svg>
        </button>       

        <footer>            
        </footer>

        <script>
            const backToTop = document.getElementById("backToTop");

            const scrollTargets = [
                window,
                document.documentElement,
                document.body,
                document.querySelector(".container"),
                document.querySelector(".posts"),
                document.querySelector(".publication"),
                document.querySelector(".resume")
            ].filter(Boolean);

            function getMaxScrollTop() {
                return Math.max(
                window.scrollY || 0,
                document.documentElement.scrollTop || 0,
                document.body.scrollTop || 0,
                document.querySelector(".container")?.scrollTop || 0,
                document.querySelector(".posts")?.scrollTop || 0,
                document.querySelector(".publication")?.scrollTop || 0,
                document.querySelector(".resume")?.scrollTop || 0
                );
            }

            function toggleBackToTop() {
                backToTop.classList.toggle("is-visible", getMaxScrollTop() > 150);
            }

            function scrollAllToTop() {
                window.scrollTo({ top: 0, behavior: "smooth" });
                document.documentElement.scrollTo?.({ top: 0, behavior: "smooth" });
                document.body.scrollTo?.({ top: 0, behavior: "smooth" });

                document.querySelector(".container")?.scrollTo({ top: 0, behavior: "smooth" });
                document.querySelector(".posts")?.scrollTo({ top: 0, behavior: "smooth" });
                document.querySelector(".publication")?.scrollTo({ top: 0, behavior: "smooth" });
                document.querySelector(".resume")?.scrollTo({ top: 0, behavior: "smooth" });
            }

            scrollTargets.forEach((target) => {
                target.addEventListener("scroll", toggleBackToTop, { passive: true });
            });

            backToTop.addEventListener("click", scrollAllToTop);
            toggleBackToTop();
        </script>
        <script src="https://cdn.jsdelivr.net/npm/prismjs/prism.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/prismjs/components/prism-javascript.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/prismjs/components/prism-python.min.js"></script>
    </body>
</html>
